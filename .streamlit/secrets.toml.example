# Local development secrets — copy to secrets.toml and edit
# This file serves as a template for new developers.
# secrets.toml is in .gitignore and will NOT be committed.

# ── Database (optional; defaults to SQLite at data/crm_logs.db) ──
# Uncomment to use PostgreSQL instead:
# DATABASE_URL = "postgresql://user:password@host:5432/dbname"

# ── Auth ──
# Users are managed through the app registration form or the
# `python manage_users.py` CLI.
